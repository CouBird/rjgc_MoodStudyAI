APP_HOST=127.0.0.1
APP_PORT=8080

DATABASE_ENABLED=true
DATABASE_URL=mysql://root:password@127.0.0.1:3306/ai_study_mood
DATABASE_MAX_CONNECTIONS=5

REDIS_ENABLED=false
REDIS_URL=redis://127.0.0.1:6379

JWT_SECRET=change-me-in-development
JWT_USER_EXPIRE_HOURS=24
JWT_ADMIN_EXPIRE_HOURS=8

AVATAR_DIR=storage/avatars
MAX_AVATAR_BYTES=3145728

# Generic AI provider placeholders. Put real keys only in backend/.env.
AI_PROVIDER=dashscope
AI_API_KEY= // 从DashScope获取的API密钥
AI_API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_MODEL=qwen-math-turbo
